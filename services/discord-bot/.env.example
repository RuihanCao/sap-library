DATABASE_URL=postgresql://user:pass@host:5432/dbname
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Optional: faster slash command updates in one server
DISCORD_GUILD_ID=

# Optional allowlists
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=

# Optional static auto-watch channels (comma-separated)
DISCORD_AUTO_INGEST_CHANNEL_IDS=

# Optional: set to false to skip command registration on boot
DISCORD_REGISTER_COMMANDS=true

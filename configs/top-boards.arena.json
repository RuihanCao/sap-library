{
  "configName": "top-boards-v1-arena",
  "dataset": {
    "version": "current",
    "matchTypes": [
      "arena"
    ],
    "sides": [
      "player",
      "opponent"
    ],
    "excludePacks": [
      "Custom",
      "Weekly"
    ],
    "minTurn": 1,
    "maxTurn": null,
    "maxBoards": 1000,
    "sampleSeed": 1337,
    "dedupeByBoardHash": true
  },
  "stages": {
    "qualifier": {
      "strategy": "random-opponents",
      "opponentsPerBoard": 8,
      "simulationCount": 1,
      "keepTop": 120
    },
    "semifinal": {
      "strategy": "swiss",
      "rounds": 7,
      "simulationCount": 2,
      "keepTop": 36
    },
    "final": {
      "strategy": "round-robin",
      "topN": 30,
      "simulationCount": 4
    }
  },
  "rating": {
    "algorithm": "elo",
    "initialRating": 1500,
    "kFactor": 16,
    "drawValue": 0.5
  },
  "execution": {
    "workers": 6,
    "batchSize": 120,
    "maxMinutes": 90,
    "retryOnError": 1,
    "onSimulationError": "count_as_draw",
    "checkpointEveryPairs": 300
  },
  "publish": {
    "scopeKeyTemplate": "version={version}|matchType={matchTypes}|sides={sides}",
    "replaceLatest": true
  }
}
